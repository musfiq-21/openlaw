# API Keys (Get these from respective providers)
# Google Gemini API Key (Recommended - Free for educational use)
GOOGLE_API_KEY=AIzaSyBiXJIYF6kGuNBJmob02HLsTd5_C5QMxXw

# OpenAI API Key (Optional - Paid)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (Optional - Paid)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LLM Configuration
LLM_PROVIDER=google
MODEL_NAME=gemini-1.5-flash
TEMPERATURE=0.1
MAX_TOKENS=2000

# Embedding Configuration (Free - HuggingFace)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# RAG Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5

# Vector Database Configuration
VECTOR_DB_PATH=./chroma_db
COLLECTION_NAME=constitution_collection

# Server Configuration
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=*

# Instructions:
# 1. Copy this file to .env (don't commit .env to git)
# 2. Get your Google Gemini API key from: https://makersuite.google.com/app/apikey
# 3. Replace 'your_google_gemini_api_key_here' with your actual API key
# 4. For production, consider using specific origins instead of '*'
# 5. Adjust other parameters as needed
